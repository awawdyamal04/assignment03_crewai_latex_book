# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# .env is git-ignored; only this example (with placeholders) is tracked.

# ── LLM provider key (used by CrewAI agents) ────────────────────────────────
# CrewAI defaults to OpenAI; set the key for whichever provider you configure.
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override the model CrewAI uses (see src/config.py in Phase 2).
# OPENAI_MODEL_NAME=gpt-4o-mini

# ── Web search tool key (Researcher agent — SerperDevTool) ──────────────────
SERPER_API_KEY=your-serper-api-key-here
